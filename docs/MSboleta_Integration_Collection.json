        {
          "name": "Actualizar productos de boleta",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test(\"Se actualizó la boleta con nuevos totales\", function () {",
                  "    pm.expect(data.productos).to.be.an('array');",
                  "    pm.expect(data.productos[0].cantidad).to.eql(3);",
                  "});"
                ]
              }
            }
