{
  "info": {
    "_postman_id": "84c8a2b5-e6fb-49d6-96b6-d249f05a9634",
    "name": "MSboleta System Integration (Sin Seguridad)",
    "description": "Colección de integración local para probar el microservicio MSboleta. No incluye Spring Security ni headers de autorización, enfocada en la lógica de negocio de boletas y recetas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Recetas",
      "item": [
        {
          "name": "Registrar receta demo",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test(\"Receta registrada correctamente con ID\", function () {",
                  "    pm.expect(data.id).to.be.a('number');",
                  "    pm.expect(data.runCliente).to.eql(pm.environment.get(\"demo_run_cliente\"));",
                  "});",
                  "pm.environment.set(\"receta_id\", String(data.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"runCliente\": \"{{demo_run_cliente}}\",\n  \"tipoReceta\": \"receta retenida\",\n  \"folioReceta\": \"REC-889900\",\n  \"fechaEmision\": \"2026-05-20\",\n  \"fechaVencimiento\": \"2026-07-20\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/recetas-clientes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "recetas-clientes"
              ]
            }
          }
        },
        {
          "name": "Consultar receta por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test(\"ID consultado coincide con el registrado\", function () {",
                  "    pm.expect(data.id).to.eql(parseInt(pm.environment.get(\"receta_id\")));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/recetas-clientes/{{receta_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "recetas-clientes",
                "{{receta_id}}"
              ]
            }
          }
        },
        {
          "name": "Listar recetas por RUN de cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test(\"Retorna una lista del cliente demo\", function () {",
                  "    pm.expect(data).to.be.an('array');",
                  "    pm.expect(data[0].runCliente).to.eql(pm.environment.get(\"demo_run_cliente\"));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/recetas-clientes/cliente/{{demo_run_cliente}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "recetas-clientes",
                "cliente",
                "{{demo_run_cliente}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "02 Boletas",
      "item": [
        {
          "name": "Crear boleta demo (Venta mixta)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test(\"Boleta creada correctamente\", function () {",
                  "    pm.expect(data.id).to.be.a('number');",
                  "    pm.expect(data.folio).to.be.a('number');",
                  "    pm.expect(data.cliente.run).to.eql(pm.environment.get(\"demo_run_cliente\"));",
                  "    pm.expect(data.montoBruto).to.be.a('number');",
                  "});",
                  "pm.environment.set(\"boleta_id\", String(data.id));",
                  "pm.environment.set(\"boleta_folio\", String(data.folio));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
